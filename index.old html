house(12,22);


/* ================= GIANT PINE TREES ================= */

function giantPine(x, z) {

    const trunk = new THREE.Mesh(
        new THREE.CylinderGeometry(0.8,1.2,16),
        new THREE.MeshLambertMaterial({
            color: 0x5b3418
        })
    );

    trunk.position.set(x,8,z);

    scene.add(trunk);


    for(let i=0;i<5;i++){

        const leaves = new THREE.Mesh(
            new THREE.ConeGeometry(
                4 - i*0.3,
                4,
                8
            ),
            new THREE.MeshLambertMaterial({
                color:0x0f6a12
            })
        );

        leaves.position.set(
            x,
            12 + i*2.5,
            z
        );

        scene.add(leaves);
    }
}

for(let i=0;i<30;i++){

