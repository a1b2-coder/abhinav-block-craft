/* ================= MOUNTAINS ================= */

function createMountain(cx, cz, radius, height) {

    const stoneMaterial = new THREE.MeshLambertMaterial({
        color: 0x888888
    });

    for (let x = -radius; x < radius; x++) {

        for (let z = -radius; z < radius; z++) {

            const dist = Math.sqrt(x*x + z*z);

            if (dist < radius) {

                const h = Math.floor(
                    (1 - dist / radius) * height
                );

                for (let y = 0; y < h; y++) {

                    const block = new THREE.Mesh(
                        new THREE.BoxGeometry(1,1,1),
                        stoneMaterial
                    );

                    block.position.set(
                        cx + x,
                        y + 0.5,
                        cz + z
                    );

                    scene.add(block);
                }
            }
        }
    }
}

