createMountain(45, -40, 15, 16);
createMountain(0, -60, 20, 22);


/* ================= RIVER ================= */

const waterMaterial = new THREE.MeshPhongMaterial({
    color: 0x3399ff,
    transparent: true,
    opacity: 0.8
});

for (let z = -80; z < 80; z++) {

    const riverWidth = 5 + Math.sin(z * 0.1) * 2;

    for (let x = -riverWidth; x < riverWidth; x++) {

        const water = new THREE.Mesh(
            new THREE.BoxGeometry(1, 0.2, 1),
            waterMaterial
        );

        water.position.set(
            x + Math.sin(z * 0.15) * 6,
            0.1,
            z
        );

        scene.add(water);
    }
}


/* ================= VILLAGE PATHS ================= */

const roadMaterial = new THREE.MeshLambertMaterial({
    color: 0x7a7a7a
});

function road(x1, z1, x2, z2) {

    const dx = x2 - x1;
    const dz = z2 - z1;

    const length = Math.sqrt(dx*dx + dz*dz);

    const r = new THREE.Mesh(
        new THREE.BoxGeometry(length, 0.1, 3),
        roadMaterial
    );

    r.position.set(
        (x1+x2)/2,
        0.05,
        (z1+z2)/2
    );

    r.rotation.y = Math.atan2(dz, dx);

    scene.add(r);
}

road(-20,10,20,10);
road(0,-10,0,30);


